# Copy this file to the REPO ROOT as ".discord_bot.env" (one level up from bot/)
# and fill in your real values. The real file is gitignored — never commit it.
#
#   copy bot\.discord_bot.env.example .discord_bot.env
#
DISCORD_BOT_TOKEN=paste-your-bot-token-here
DISCORD_BOT_CHANNEL_ID=paste-the-channel-id-here
